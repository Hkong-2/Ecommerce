// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
}

// ==========================================
// 1. QUẢN LÝ NGƯỜI DÙNG & ĐỊA CHỈ
// ==========================================

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  fullName  String
  phone     String?
  role      Role      @default(USER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  addresses Address[]
  orders    Order[]
  cartItems CartItem[]
}

enum Role {
  USER
  ADMIN
}

model Address {
  id            Int     @id @default(autoincrement())
  userId        Int
  receiverName  String  // Tên người nhận (có thể khác tên user)
  receiverPhone String  // SĐT người nhận
  street        String  // Số nhà, tên đường
  ward          String  // Phường/Xã
  district      String  // Quận/Huyện
  city          String  // Tỉnh/Thành phố
  isDefault     Boolean @default(false)

  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders        Order[]
}

// ==========================================
// 2. QUẢN LÝ SẢN PHẨM & BIẾN THỂ (GIÀY)
// ==========================================

model Category {
  id          Int       @id @default(autoincrement())
  name        String    // VD: Sneakers, Giày chạy bộ, Giày da
  slug        String    @unique
  description String?
  
  products    Product[]
}

model Product {
  id          Int       @id @default(autoincrement())
  categoryId  Int
  name        String    // VD: Nike Air Force 1 '07
  slug        String    @unique
  description String    @db.Text
  brand       String    // VD: Nike, Adidas, Vans
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  category    Category  @relation(fields: [categoryId], references: [id])
  skus        SKU[]
}

model SKU {
  id          Int       @id @default(autoincrement())
  productId   Int
  skuCode     String    @unique // VD: NK-AF1-WHT-42 (Hãng-Mẫu-Màu-Size)
  price       Float     // Giá bán hiện tại
  stock       Int       // Số lượng tồn kho
  
  // Lưu các biến thể linh hoạt bằng JSONB của PostgreSQL
  // VD: { "size": 42, "color": "Trắng", "material": "Da" }
  attributes  Json      

  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems   CartItem[]
  orderItems  OrderItem[]
}

// ==========================================
// 3. GIỎ HÀNG (DỮ LIỆU TẠM)
// ==========================================

model CartItem {
  id        Int      @id @default(autoincrement())
  userId    Int
  skuId     Int
  quantity  Int      @default(1)
  addedAt   DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sku       SKU      @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@unique([userId, skuId]) // Một user chỉ có 1 dòng cho 1 SKU trong giỏ, nếu thêm nữa thì cộng dồn quantity
}

// ==========================================
// 4. ĐƠN HÀNG & BẢO TOÀN LỊCH SỬ
// ==========================================

model Order {
  id               Int      @id @default(autoincrement())
  userId           Int
  addressId        Int
  orderCode        String   @unique // Mã đơn hàng ngắn gọn cho khách dễ tra cứu (VD: ORD-20260317-XYZ)
  
  status           OrderStatus @default(PENDING)
  paymentMethod    String      // VD: COD, VNPAY, STRIPE
  paymentStatus    String      @default("UNPAID") // UNPAID, PAID, REFUNDED
  
  shippingFee      Float       @default(0) // Phí ship tính riêng
  totalAmount      Float       // Tổng tiền khách phải trả cuối cùng
  note             String?     @db.Text
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User                 @relation(fields: [userId], references: [id])
  address          Address              @relation(fields: [addressId], references: [id])
  items            OrderItem[]
  statusHistory    OrderStatusHistory[]
}

enum OrderStatus {
  PENDING     // Chờ xác nhận
  PROCESSING  // Đang đóng gói
  SHIPPING    // Đang giao hàng
  COMPLETED   // Đã giao thành công
  CANCELLED   // Đã hủy
}

model OrderItem {
  id                  Int    @id @default(autoincrement())
  orderId             Int
  skuId               Int?   // Để optional, đề phòng sau này lỡ xóa SKU thì đơn hàng cũ không bị lỗi
  quantity            Int

  // --- DATA SNAPSHOT (LƯU CHẾT THÔNG TIN LÚC MUA) ---
  productNameSnapshot String // Lưu cứng tên "Nike Air Force 1 '07 - Trắng - Size 42"
  unitPrice           Float  // Giá gốc 1 đôi lúc mua (VD: 2.500.000)
  discountAmount      Float  @default(0) // Mức giảm giá 1 đôi lúc mua (VD: 500.000)
  finalPrice          Float  // Giá thực tế thanh toán cho 1 đôi (VD: 2.000.000)
  
  order               Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sku                 SKU?   @relation(fields: [skuId], references: [id], onDelete: SetNull)
}

model OrderStatusHistory {
  id        Int         @id @default(autoincrement())
  orderId   Int
  status    OrderStatus
  note      String?     // Ghi chú thêm (VD: "Khách hẹn giao lại vào ngày mai")
  createdBy Int?        // ID của nhân viên cập nhật trạng thái (nếu có)
  createdAt DateTime    @default(now())

  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
}
